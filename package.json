{
  "name": "spotifyappleproject",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:relay": "npm run dev -w apps/relay",
    "dev:web": "npm run dev -w apps/web",
    "dev:mobile": "npm run start -w apps/mobile",
    "build": "npm run build -w packages/shared && npm run build -w apps/relay && npm run build -w apps/web",
    "test": "npm run test -w apps/relay && npm run test -w apps/web && npm run test -w apps/mobile"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  },
  "overrides": {
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-constants": "~17.0.8",
    "metro-resolver": "^0.81.0",
    "react-native": "0.76.9"
  }
}
