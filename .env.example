# --- Local dev values (read from this file via dotenv) ---
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Local dev: path to the .p8 key file, relative to the repo root.
APPLE_PRIVATE_KEY_PATH=./AuthKey_<key-id>.p8
# Production (Render): paste the .p8 file's raw contents into this var instead
# of APPLE_PRIVATE_KEY_PATH — there's no file to point at on the host. Either
# real newlines or escaped "\n" work, appleToken.ts normalizes both.
APPLE_PRIVATE_KEY=

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Browser-exposed mirrors (Vite only injects VITE_-prefixed vars into the client bundle).
# Do NOT add a VITE_ mirror of SPOTIFY_CLIENT_SECRET.
# Production (Vercel): set these three as project env vars instead of via this
# file — VITE_SPOTIFY_REDIRECT_URI becomes the Vercel URL's root path (e.g.
# https://<app>.vercel.app/) and VITE_RELAY_URL becomes wss://<render-host>.
VITE_SPOTIFY_CLIENT_ID=
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
VITE_RELAY_URL=ws://127.0.0.1:8787
