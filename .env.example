APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=./AuthKey_<key-id>.p8

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Browser-exposed mirrors (Vite only injects VITE_-prefixed vars into the client bundle).
# Do NOT add a VITE_ mirror of SPOTIFY_CLIENT_SECRET.
VITE_SPOTIFY_CLIENT_ID=
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
VITE_RELAY_URL=ws://127.0.0.1:8787
